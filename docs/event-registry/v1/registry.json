        "required_context": ["card_id", "registration_id"],
        "optional_context": ["deck_id", "module_id"],
        "required_payload": [],
        "optional_payload": ["position", "presentation_mode"]
      },
      "xapi_mapping": {
        "verb": "http://adlnet.gov/expapi/verbs/experienced",
