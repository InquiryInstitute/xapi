      "internal_event": {
        "required_context": ["resource_id", "registration_id"],
        "optional_context": ["module_id"],
        "required_payload": [],
        "optional_payload": ["mime_type", "duration_ms"]
      },
      "xapi_mapping": {
        "verb": "http://adlnet.gov/expapi/verbs/experienced",
        "activity_type": "https://castalia.institute/xapi/activity-types/learning-resource",
        "activity_id_template": "https://castalia.institute/xapi/activities/resource/{resource_id}",
        "context_extension_keys": ["castalia_event_type", "registration_id"]
      }
    },
    {
      "event_type": "castalia.atlas.assessment.attempt_submitted",
      "version": "1.0",
      "title": "Assessment attempt submitted",
      "description": "Learner submitted an attempt for a graded assessment.",
      "producers": ["atlas"],
      "internal_event": {
        "required_context": ["assessment_id", "registration_id"],
        "optional_context": ["module_id"],
        "required_payload": ["attempt_id"],
        "optional_payload": ["item_count", "time_limit_ms"]
      },
      "xapi_mapping": {
        "verb": "http://adlnet.gov/expapi/verbs/answered",
        "activity_type": "https://castalia.institute/xapi/activity-types/assessment",
        "activity_id_template": "https://castalia.institute/xapi/activities/assessment/{assessment_id}",
        "context_extension_keys": ["castalia_event_type", "registration_id", "attempt_id"]
      }
    },
    {
      "event_type": "castalia.atlas.assessment.scored",
      "version": "1.0",
      "title": "Assessment scored",
      "description": "System recorded a score or outcome for an assessment attempt.",
      "producers": ["atlas"],
      "internal_event": {
        "required_context": ["assessment_id", "registration_id", "attempt_id"],
        "optional_context": ["module_id"],
        "required_payload": ["score_min", "score_max", "score_raw"],
        "optional_payload": ["passed", "graded_at"]
      },
      "xapi_mapping": {
        "verb": "http://adlnet.gov/expapi/verbs/completed",
        "activity_type": "https://castalia.institute/xapi/activity-types/assessment",
        "activity_id_template": "https://castalia.institute/xapi/activities/assessment/{assessment_id}",
        "context_extension_keys": ["castalia_event_type", "registration_id", "attempt_id"],
        "result_required": ["score", "success"]
      },
      "notes": "Scoring event: use result.score (scaled or raw per profile) and result.success; verb is ADL completed to maximize LRS interoperability."
    },
    {
      "event_type": "castalia.dialogic.session.started",
      "version": "1.0",
      "title": "Dialogic session started",
      "description": "SAMWISE / Dialogic conversational session began.",
