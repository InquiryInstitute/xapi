{
  "registry_version": "1.0",
  "spec_reference": "docs/CASTALIA_XAPI_SYSTEM_SPEC_v0.1.md",
  "namespace": "castalia",
  "iri_base": {
    "activity_type": "https://castalia.institute/xapi/activity-types/",
    "activity": "https://castalia.institute/xapi/activities/",
    "extension": "https://castalia.institute/xapi/extensions/"
  },
  "events": [
    {
      "event_type": "castalia.inqspace.notebook.cell_executed",
      "version": "1.0",
      "title": "Notebook cell executed",
      "description": "A code or markdown cell ran to completion or failure in an iNQspace notebook.",
      "producers": ["inqspace", "atlas"],
      "internal_event": {
        "required_context": ["notebook_id", "session_id"],
        "optional_context": ["course_id", "module_id"],
        "required_payload": ["cell_id"],
        "optional_payload": ["language", "kernel_id", "execution_ms", "success", "error_code"]
      },
      "xapi_mapping": {
        "verb": "http://adlnet.gov/expapi/verbs/interacted",
        "activity_type": "https://castalia.institute/xapi/activity-types/notebook-cell",
        "activity_id_template": "https://castalia.institute/xapi/activities/notebook/{notebook_id}/cell/{cell_id}",
        "context_extension_keys": ["castalia_event_type", "notebook_id", "session_id"],
        "result_required": ["success"]
      }
    },
    {
      "event_type": "castalia.inqspace.notebook.kernel_ready",
      "version": "1.0",
      "title": "Notebook kernel ready",
      "description": "Compute kernel for a notebook session became ready for execution.",
      "producers": ["inqspace"],
      "internal_event": {
        "required_context": ["notebook_id", "session_id"],
        "optional_context": ["course_id"],
        "required_payload": ["kernel_id"],
        "optional_payload": ["language", "startup_ms"]
      },
      "xapi_mapping": {
        "verb": "http://adlnet.gov/expapi/verbs/initialized",
        "activity_type": "https://castalia.institute/xapi/activity-types/notebook-kernel",
        "activity_id_template": "https://castalia.institute/xapi/activities/notebook/{notebook_id}/kernel/{kernel_id}",
        "context_extension_keys": ["castalia_event_type", "notebook_id", "session_id"]
      }
    },
    {
      "event_type": "castalia.atlas.module.started",
      "version": "1.0",
      "title": "Learning module started",
      "description": "Learner began a structured module or lesson sequence in Atlas.",
      "producers": ["atlas"],
      "internal_event": {
        "required_context": ["module_id", "registration_id"],
        "optional_context": ["pathway_id", "cohort_id"],
        "required_payload": [],
        "optional_payload": ["attempt", "entry_point"]
      },
      "xapi_mapping": {
        "verb": "http://adlnet.gov/expapi/verbs/initialized",
        "activity_type": "https://castalia.institute/xapi/activity-types/learning-module",
        "activity_id_template": "https://castalia.institute/xapi/activities/module/{module_id}",
        "context_extension_keys": ["castalia_event_type", "registration_id"]
      }
    },
    {
      "event_type": "castalia.atlas.module.completed",
      "version": "1.0",
      "title": "Learning module completed",
      "description": "Learner satisfied completion criteria for a module.",
      "producers": ["atlas"],
      "internal_event": {
        "required_context": ["module_id", "registration_id"],
        "optional_context": ["pathway_id"],
        "required_payload": [],
        "optional_payload": ["score", "success", "duration_ms"]
      },
      "xapi_mapping": {
        "verb": "http://adlnet.gov/expapi/verbs/completed",
        "activity_type": "https://castalia.institute/xapi/activity-types/learning-module",
        "activity_id_template": "https://castalia.institute/xapi/activities/module/{module_id}",
        "context_extension_keys": ["castalia_event_type", "registration_id"],
        "result_required": ["completion"]
      }
    },
    {
      "event_type": "castalia.atlas.resource.accessed",
      "version": "1.0",
