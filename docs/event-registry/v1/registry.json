      "internal_event": {
        "required_context": ["dialogic_session_id", "registration_id"],
        "optional_context": ["scenario_id", "locale"],
        "required_payload": [],
        "optional_payload": ["model_id", "prompt_pack_id"]
      },
      "xapi_mapping": {
        "verb": "http://adlnet.gov/expapi/verbs/initialized",
        "activity_type": "https://castalia.institute/xapi/activity-types/dialogic-session",
        "activity_id_template": "https://castalia.institute/xapi/activities/dialogic/{dialogic_session_id}",
        "context_extension_keys": ["castalia_event_type", "registration_id"]
      }
    },
    {
      "event_type": "castalia.dialogic.session.ended",
      "version": "1.0",
      "title": "Dialogic session ended",
      "description": "Dialogic session closed normally or by policy.",
      "producers": ["samwise", "dialogic"],
      "internal_event": {
        "required_context": ["dialogic_session_id", "registration_id"],
        "optional_context": ["scenario_id"],
        "required_payload": [],
        "optional_payload": ["turn_count", "duration_ms", "end_reason"]
      },
      "xapi_mapping": {
        "verb": "http://adlnet.gov/expapi/verbs/terminated",
        "activity_type": "https://castalia.institute/xapi/activity-types/dialogic-session",
        "activity_id_template": "https://castalia.institute/xapi/activities/dialogic/{dialogic_session_id}",
        "context_extension_keys": ["castalia_event_type", "registration_id"]
      },
      "notes": "Session end: use result extensions for turn_count, duration_ms, end_reason where applicable."
    },
    {
      "event_type": "castalia.dialogic.turn.submitted",
      "version": "1.0",
      "title": "Dialogic turn submitted",
      "description": "Learner or agent submitted one turn in a dialogic exchange.",
      "producers": ["samwise", "dialogic"],
      "internal_event": {
        "required_context": ["dialogic_session_id", "registration_id"],
        "optional_context": ["scenario_id"],
        "required_payload": ["turn_id", "role"],
        "optional_payload": ["token_count", "latency_ms"]
      },
      "xapi_mapping": {
        "verb": "http://adlnet.gov/expapi/verbs/answered",
        "activity_type": "https://castalia.institute/xapi/activity-types/dialogic-turn",
        "activity_id_template": "https://castalia.institute/xapi/activities/dialogic/{dialogic_session_id}/turn/{turn_id}",
        "context_extension_keys": ["castalia_event_type", "registration_id", "role"]
      },
      "notes": "Store raw text only in approved privacy mode; prefer hashes or redacted summaries in extensions."
    },
    {
      "event_type": "castalia.inq.card.presented",
      "version": "1.0",
      "title": "Inquiry card presented",
